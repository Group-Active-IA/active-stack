<Window x:Class="ActiveStack.Bootstrapper.Host.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Active Stack Setup"
        Height="560"
        Width="760"
        MinWidth="640"
        MinHeight="480"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#FFF3F4F6">
  <Window.Resources>
    <Style x:Key="FooterButtonStyle" TargetType="Button">
      <Setter Property="Height" Value="36" />
      <Setter Property="MinWidth" Value="96" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#D1D5DB" />
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="#111827" />
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource FooterButtonStyle}">
      <Setter Property="Background" Value="#111827" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
  </Window.Resources>

  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="16" />
      <RowDefinition Height="*" />
      <RowDefinition Height="16" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header: the current page's title/subtitle. -->
    <StackPanel Grid.Row="0">
      <TextBlock Text="{Binding CurrentPage.Title}"
                 FontSize="22"
                 FontWeight="SemiBold"
                 Foreground="#111827" />
      <TextBlock Margin="0,6,0,0"
                 Text="{Binding CurrentPage.Subtitle}"
                 FontSize="13"
                 Foreground="#4B5563"
                 TextWrapping="Wrap" />
    </StackPanel>

    <!-- Body: the current page's view, selected by DataTemplate on the page-VM's type (D1, design.md). -->
    <Border Grid.Row="2"
            Background="White"
            CornerRadius="12"
            BorderBrush="#E5E7EB"
            BorderThickness="1"
            Padding="20">
      <ContentControl Content="{Binding CurrentPage}" />
    </Border>

    <!-- Footer: Back / primary (Next or Install) / Cancel. Hidden footer buttons stay laid out but disabled while Installing/Complete have no nav. -->
    <Grid Grid.Row="4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="12" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Button Grid.Column="0"
              Content="Back"
              Style="{StaticResource FooterButtonStyle}"
              IsEnabled="{Binding CanGoBack}"
              Click="BackButton_Click" />

      <Button Grid.Column="2"
              Content="Cancel"
              Style="{StaticResource FooterButtonStyle}"
              Click="CancelButton_Click" />

      <Button Grid.Column="4"
              Content="{Binding PrimaryLabel}"
              Style="{StaticResource PrimaryButtonStyle}"
              IsDefault="True"
              IsEnabled="{Binding PrimaryEnabled}"
              Click="PrimaryButton_Click" />
    </Grid>
  </Grid>
</Window>
